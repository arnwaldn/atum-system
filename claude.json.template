{
  "_comment": "Claude Code MCP Servers — Portable template. Replace placeholders before use.",
  "_instructions": "REPLACE_WITH_HOME_DIR → your home directory (e.g. C:/Users/you or /Users/you) | REPLACE_ATUM_USER → arnaud/pablo/wahid | Secrets via env vars in ~/.bashrc: GITHUB_PERSONAL_ACCESS_TOKEN, GOOGLE_OAUTH_CLIENT_SECRET, GOOGLE_OAUTH_CLIENT_ID, OPENAPI_MCP_HEADERS, AIRTABLE_API_KEY, HINDSIGHT_API_KEY, GROQ_API_KEY",
  "mcpServers": {
    "memory": {
      "command": "cmd",
      "args": [
        "/c",
        "npx",
        "-y",
        "@modelcontextprotocol/server-memory"
      ]
    },
    "sequential-thinking": {
      "command": "cmd",
      "args": [
        "/c",
        "npx",
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ]
    },
    "vercel": {
      "type": "http",
      "url": "https://mcp.vercel.com"
    },
    "railway": {
      "command": "cmd",
      "args": [
        "/c",
        "npx",
        "-y",
        "@railway/mcp-server"
      ]
    },
    "cloudflare-docs": {
      "type": "http",
      "url": "https://docs.mcp.cloudflare.com/mcp"
    },
    "context7": {
      "command": "cmd",
      "args": [
        "/c",
        "npx",
        "-y",
        "@upstash/context7-mcp"
      ]
    },
    "magic": {
      "command": "cmd",
      "args": [
        "/c",
        "npx",
        "-y",
        "@magicuidesign/mcp@latest"
      ]
    },
    "google-workspace": {
      "type": "stdio",
      "command": "$UV_EXE_PATH",
      "args": [
        "run",
        "--project",
        "$HOME/Projects/tools/google_workspace_mcp",
        "$HOME/Projects/tools/google_workspace_mcp/main.py",
        "--single-user",
        "--tool-tier",
        "extended"
      ],
      "env": {
        "GOOGLE_OAUTH_CLIENT_ID": "$GOOGLE_OAUTH_CLIENT_ID"
      }
    },
    "desktop-commander": {
      "command": "cmd",
      "args": [
        "/c",
        "npx",
        "-y",
        "@wonderwhy-er/desktop-commander"
      ]
    },
    "github": {
      "type": "stdio",
      "command": "cmd",
      "args": [
        "/c",
        "npx",
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "env": {}
    },
    "b12": {
      "command": "node",
      "args": [
        "REPLACE_WITH_HOME_DIR/Projects/tools/website-generator-mcp-server/src/server.js"
      ]
    },
    "atum-audit": {
      "command": "cmd",
      "args": [
        "/c",
        "python",
        "REPLACE_WITH_HOME_DIR/Desktop/agent-owl/atum_mcp_server.py"
      ],
      "env": {
        "ATUM_PROJECT_DIR": "REPLACE_WITH_HOME_DIR/Desktop/agent-owl"
      }
    },
    "webmcp": {
      "command": "node",
      "args": [
        "REPLACE_WITH_HOME_DIR/Projects/tools/webmcp-optimized/src/websocket-server.js",
        "--mcp"
      ]
    },
    "skillsync": {
      "command": "cmd",
      "args": [
        "/c",
        "npx",
        "-y",
        "@stranzwersweb2/skillsync-mcp@latest"
      ]
    },
    "notion": {
      "command": "cmd",
      "args": [
        "/c",
        "npx",
        "-y",
        "@notionhq/notion-mcp-server"
      ],
      "env": {}
    },
    "airtable": {
      "command": "cmd",
      "args": [
        "/c",
        "npx",
        "-y",
        "airtable-mcp-server"
      ],
      "env": {}
    },
    "figma": {
      "type": "http",
      "url": "https://mcp.figma.com/mcp"
    },
    "webflow": {
      "type": "http",
      "url": "https://mcp.webflow.com/sse"
    },
    "make": {
      "type": "http",
      "url": "https://mcp.make.com"
    },
    "hindsight-shared": {
      "type": "http",
      "url": "https://arnwald84-atum-hindsight.hf.space/mcp/atum/",
      "headers": {
        "Authorization": "Bearer ${HINDSIGHT_API_KEY}"
      }
    },
    "hindsight-personal": {
      "type": "http",
      "url": "https://arnwald84-atum-hindsight.hf.space/mcp/REPLACE_ATUM_USER/",
      "headers": {
        "Authorization": "Bearer ${HINDSIGHT_API_KEY}"
      }
    },
    "whatsapp": {
      "type": "stdio",
      "command": "$UV_EXE_PATH",
      "args": [
        "--directory",
        "$HOME/Projects/tools/whatsapp-mcp/whatsapp-mcp-server",
        "run",
        "main.py"
      ]
    }
  }
}
