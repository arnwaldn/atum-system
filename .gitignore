# Claude Code Config Backup - .gitignore
# Only backup essential configuration files

# === SENSITIVE - NEVER commit ===
.credentials.json
*.credentials*

# === Auto-generated caches (Claude Code internal) ===
# Note: plugins/ directory is tracked (ATUM plugin architecture v4)
debug/
file-history/
statsig/
backups/
cache/
chrome/
paste-cache/
plans/
sessions/
shell-snapshots/
tasks/
todos/
mcp-needs-auth-cache.json
security_warnings_state_*.json

# === Session data (exclude logs, keep memory) ===
history.jsonl
*.jsonl
# Track projects/*/memory/ for MEMORY.md but exclude session transcripts
projects/**/sessions/
projects/**/*.jsonl
# Exclude UUID session directories (subagents, tool-results)
projects/*/[0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f]-*/

# === Auto-generated skills ===
skills/learned/

# === Python cache ===
__pycache__/
*.pyc

# === OS files ===
.DS_Store
Thumbs.db
desktop.ini

# === Image & media caches ===
image-cache/

# ATUM Audit
audit_store/

# Scheduler history (SQLite runtime data)
schedules/.history/

# Embedded repos & runtime data
collective-memory/
hindsight-mirror/
hindsight-export/
hindsight-pending/
session-env/
telemetry/

# Transient runtime data
instincts/
memory/
graph-queue/
homunculus/
downloads/
common-ground/
ide/
tmp/

# === Schedules perso (non partag�s) ===
schedules/appart-aix-search.json
schedules/whatsapp-cloclo-respond.json

# === Fichiers backup auto ===
*.backup.*
