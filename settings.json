{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(*)",
      "Write(*)",
      "Edit(*)",
      "NotebookEdit(*)",
      "Task(*)",
      "EnterPlanMode",
      "ExitPlanMode",
      "EnterWorktree(*)",
      "WebFetch(*)",
      "mcp__claude-in-chrome__*",
      "mcp__github__*",
      "mcp__memory__*",
      "mcp__google-workspace__*",
      "mcp__sequential-thinking__*",
      "mcp__railway__*",
      "mcp__cloudflare-docs__*",
      "mcp__context7__*",
      "mcp__magic__*",
      "mcp__desktop-commander__*",
      "mcp__plugin_firebase_firebase__*",
      "mcp__plugin_playwright_playwright__*",
      "mcp__plugin_context7_context7__*",
      "mcp__claude_ai_Canva__*",
      "mcp__claude_ai_Cloudflare_Developer_Platform__*",
      "mcp__claude_ai_Figma__*",
      "mcp__claude_ai_Gamma__*",
      "mcp__claude_ai_Gmail__*",
      "mcp__claude_ai_Google_Calendar__*",
      "mcp__claude_ai_Hugging_Face__*",
      "mcp__claude_ai_Invideo__*",
      "mcp__claude_ai_Notion__*",
      "mcp__claude_ai_Supabase__*",
      "mcp__claude_ai_Vercel__*",
      "mcp__claude_ai_Zapier__*",
      "Skill(*)",
      "WebSearch(*)",
      "ToolSearch(*)",
      "mcp__b12__*",
      "mcp__webmcp__*",
      "mcp__claude_ai_Cloudinary__*",
      "mcp__claude_ai_Context7__*",
      "mcp__claude_ai_Excalidraw__*",
      "mcp__claude_ai_GraphOS_MCP_Tools__*",
      "mcp__claude_ai_Microsoft_Learn__*",
      "mcp__claude_ai_Netlify__*",
      "mcp__claude_ai_Stripe__*",
      "mcp__claude_ai_Webflow__*",
      "mcp__skillsync__*",
      "mcp__airtable__*",
      "mcp__notion__*",
      "mcp__plugin_pinecone_pinecone__*",
      "mcp__whatsapp__*",
      "mcp__atum-audit__*",
      "mcp__plugin_serena_serena__*"
    ],
    "defaultMode": "default"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "node \"C:/Users/arnau/.claude/hooks/image-auto-resize.js\""
          }
        ]
      },
      {
        "matcher": "mcp__claude-in-chrome__browser_take_screenshot|mcp__claude-in-chrome__computer|mcp__claude-in-chrome__upload_image|mcp__claude_ai_Figma__get_screenshot|mcp__claude_ai_Canva__get-design-thumbnail|mcp__claude_ai_Excalidraw__create_view",
        "hooks": [
          {
            "type": "command",
            "command": "node \"C:/Users/arnau/.claude/hooks/image-guard.js\""
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python \"C:/Users/arnau/.claude/hooks/clean-shell-snapshots.py\""
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python \"C:/Users/arnau/.claude/hooks/secret-scanner.py\""
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python \"C:/Users/arnau/.claude/hooks/git-guard.py\""
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"C:/Users/arnau/.claude/hooks/lock-file-protector.js\""
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "if [[ -f \"$CLAUDE_TOOL_FILE_PATH\" ]]; then cp \"$CLAUDE_TOOL_FILE_PATH\" \"$CLAUDE_TOOL_FILE_PATH.backup.$(date +%s)\" 2>/dev/null || true; fi"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python \"C:/Users/arnau/.claude/hooks/atum-post-write.py\""
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python \"C:/Users/arnau/.claude/hooks/atum-compliance-check.py\""
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node \"C:/Users/arnau/.claude/hooks/post-edit-dispatcher.js\"",
            "timeout": 15000
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"C:/Users/arnau/.claude/hooks/post-commit-quality-gate.js\""
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"C:/Users/arnau/.claude/hooks/worktree-setup.js\""
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"C:/Users/arnau/.claude/hooks/loop-detector.js\""
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"C:/Users/arnau/.claude/hooks/precompact-save.js\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"C:/Users/arnau/.claude/hooks/anti-rationalization.js\""
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"C:/Users/arnau/.claude/hooks/session-memory.js\""
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"C:/Users/arnau/.claude/hooks/collective-memory-retain.js\""
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"C:/Users/arnau/.claude/hooks/atum-dashboard-sync.js\""
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"const fs=require('fs'),p=require('path').join(require('os').homedir(),'.claude','shell-snapshots');try{fs.readdirSync(p).filter(f=>f.endsWith('.sh')).forEach(f=>fs.unlinkSync(require('path').join(p,f)))}catch(e){}\""
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"C:/Users/arnau/.claude/hooks/image-guard-reset.js\""
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"C:/Users/arnau/.claude/hooks/post-tool-failure-logger.js\""
          }
        ]
      }
    ],
    "ConfigChange": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"C:/Users/arnau/.claude/hooks/config-change-guard.js\""
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "permission_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -Command \"[Console]::Beep(800,300); [Console]::Beep(1000,200)\""
          }
        ]
      },
      {
        "matcher": "idle_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -Command \"[Console]::Beep(600,500)\""
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python \"C:/Users/arnau/.claude/hooks/clean-shell-snapshots.py\""
          },
          {
            "type": "command",
            "command": "python \"C:/Users/arnau/.claude/hooks/atum-session-start.py\""
          },
          {
            "type": "command",
            "command": "node \"C:/Users/arnau/.claude/hooks/atum-project-scanner.js\""
          },
          {
            "type": "command",
            "command": "node \"C:/Users/arnau/.claude/hooks/collective-memory-start.js\"",
            "timeout": 15000
          }
        ]
      }
    ]
  },
