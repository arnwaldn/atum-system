{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "DISABLE_TELEMETRY": "1",
    "DISABLE_ERROR_REPORTING": "1",
    "CLAUDE_CODE_DISABLE_FEEDBACK_SURVEY": "1",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "cleanupPeriodDays": 365,
  "alwaysThinkingEnabled": true,
  "enableAllProjectMcpServers": false,
  "permissions": {
    "allow": [
      "Read",
      "Write",
      "Edit",
      "WebSearch",
      "Skill(*)",
      "Bash(git *)",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(uv *)",
      "Bash(python *)",
      "Bash(python3 *)",
      "Bash(node *)",
      "Bash(rg *)",
      "Bash(fd *)",
      "Bash(jq *)",
      "Bash(curl *)",
      "Bash(cat *)",
      "Bash(ls *)",
      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(mv *)"
    ],
    "deny": [
      "Read(.env*)",
      "Read(**/.*credentials*)",
      "Read(**/*secret*)",
      "Read(**/.ssh/*)",
      "Read(**/.aws/*)",
      "Write(.bashrc)",
      "Write(.zshrc)",
      "Write(.profile)",
      "Bash(rm -rf /)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf /*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 $HOME_PLACEHOLDER/.claude/hooks/file-guard.py",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "python3 $HOME_PLACEHOLDER/.claude/hooks/secret-scanner.py",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "Bash(git push*)",
        "hooks": [
          {
            "type": "command",
            "command": "python3 $HOME_PLACEHOLDER/.claude/hooks/git-guard.py",
            "timeout": 5000
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 $HOME_PLACEHOLDER/.claude/hooks/anti-rationalization.py",
            "timeout": 10000
          }
        ]
      }
    ]
  },
  "statusLine": {
    "command": "bash $HOME_PLACEHOLDER/.claude/statusline.sh"
  }
}
