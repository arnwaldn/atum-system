{
  "supabase_url_env": "ATUM_SUPABASE_URL",
  "supabase_anon_key_env": "ATUM_SUPABASE_ANON_KEY",
  "service_role_key_env": "ATUM_SUPABASE_SERVICE_KEY",
  "dashboard_url": "https://atum-dashboard.netlify.app",
  "scan_paths": [
    "$HOME/Documents",
    "$HOME/Projects",
    "$HOME/Desktop"
  ],
  "ignore_dirs": [
    "node_modules", ".git", "__pycache__", ".venv", "venv",
    "dist", "build", ".next", ".claude", "audit_store",
    "project-templates", "tools"
  ],
  "project_markers": [
    "package.json", "requirements.txt", "pyproject.toml",
    "Cargo.toml", "go.mod", "pubspec.yaml", "pom.xml",
    "build.gradle", "Makefile", "CMakeLists.txt",
    "docker-compose.yml", "Dockerfile"
  ]
}
